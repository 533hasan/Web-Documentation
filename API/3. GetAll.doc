app.get('/users', async (req, res) => {
    try {

        // 1️⃣ CREATE QUERY (empty = get all documents)
        const query = {};

        // 2️⃣ RUN QUERY
        const users = await db.collection('users')
            .find(query)
            .toArray();

        // 3️⃣ RESPONSE
        res.json(users);

    } catch (error) {
        res.status(500).json({ message: error.message });
    }
});