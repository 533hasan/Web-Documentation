
Flow:
client sends a request with a token then backend 
verify the token and give the access.

Two points:
client components may
  * server component
  * client component 



1. For sever component code from frontend:
import { headers } from "next/headers";
import { auth } from "@/lib/auth";

const DetailsPage = async () => {
    const { token } = await auth.api.getToken({
        headers: headers(),
    });

    const res = await fetch("http://localhost:3000/api/data", {
        headers: {
            Authorization: `Bearer ${token}`,
        },
    });
};


2. *** Backend code or middleware

import { jwtVerify, createRemoteJWKSet } from "jose-cjs";

const JWKS = createRemoteJWKSet(
    new URL("http://localhost:3000/api/auth/jwks");
)

// Middleware
const verifyToken = async(req, res, next)=>{
    const authHeader = req.headers.authorization;
    if(!authHeader){
        return res.status(401).json({
            message:"Unauthorized"
        });
    }
    const token = authHeader.split(" ")[1];
    if(!token){
        return res.status(401).json({
            message:"Unauthorized"
        })
    }

    // verify part 
    try{
        const{payload} = await jwtVerify(token, JWKS);
        console.log(payload);
        next();
    }catch(error){
        return res.status(403).json({
            message:"Forbidden" });
    }
}



3.API 
app.get("/destination/:id", verifyToken, async (req, res) => {
    const { id } = req.params;

    const result = await destinationCollection.findOne({
        _id: new ObjectId(id),
    });

    res.json(result);
});


4. install: npm i jose-cjs


5. *** if client component:
"use client";
import { authClient } from "@/lib/auth-client";
const BookingCard = () => {
    const handleBooking = async (bookingData) => {
        const token = await authClient.getToken();

        const res = await fetch("http://localhost:5000/booking", {
            method: "POST",
            headers: {
                "Content-Type": "application/json",
                authorization: `Bearer ${token}`,
            },
            body: JSON.stringify(bookingData),
        });

        const data = await res.json();
        console.log(data);
    };
}